<table width="100%" cellspacing="0" cellpadding="0"
    style="max-width:600px; margin:auto; background:#ffffff; border-radius:8px; overflow:hidden;">
    <!-- Header -->
    <tr>
        <td style="background:#2c3e50; color:#eed202; padding:20px; text-align:center;">
            <h1 style="margin:0;">{{wholesalerName}}</h1>
        </td>
    </tr>
    <!-- Content -->
    <tr>
        <td style="padding:20px; color:#333333;">
            <h2>Hallo {{companyName}},</h2>
            <p>vielen Dank für Ihre Bestellung!</p>
            <p><strong>Bestellnummer:</strong> #{{orderId}}</p>
            <table width="100%" style="border-collapse: collapse; margin:20px 0;">
                <tr style="background:#f0f0f0;">
                    <th align="left" style="padding:10px;">Produkt</th>
                    <th align="left" style="padding:10px">Menge</th>
                    <th align="right" style="padding:10px;">Preis/Stk</th>
                    <th align="right" style="padding:10px">Gesamtpreis</th>
                </tr>
                {{#each products}}
                    <tr>
                        <td style="padding:10px;">{{name}}</td>
                        <td style="padding:10px;">{{quantity}}</td>
                        <td align="right" style="padding:10px;">{{pricePerUnit}} €</td>
                        <td align="right" style="padding:10px;">{{subtotal}} €</td>
                    </tr>
                {{/each}}
            </table>
            <p><strong>Gesamt:</strong> {{totalPrice}} €</p>
            <p style="text-align:center; margin:30px 0;">
                <a href="https://example.com"
                    style="background:#27ae60; color:#ffffff; padding:12px 20px; text-decoration:none; border-radius:5px;">
                    Bestellung ansehen </a>
            </p>
            <p>Falls du Fragen hast, antworte einfach auf diese E-Mail.</p>
            <p>Mit freundlichen Grüßen<br />Dein {{wholesalerName}}-Team</p>
        </td>
    </tr>
    <!-- Footer -->
    <tr>
        <td style="background:#f0f0f0; padding:15px; text-align:center; font-size:12px; color:#777;"> © 2026 {{wholesalerName}} AG •
            Wien </td>
    </tr>
</table>